@section Scripts {
    <script>
        function openEditModal() {
            var prescriptionModal = new bootstrap.Modal(document.getElementById('prescriptionModal'));
            prescriptionModal.show();
        }

        $('#prescriptionForm').submit(function (e) {
            e.preventDefault();

            const formData = {
                doctorId: $('#doctorId').val(),
                patientId: $('#patientId').val(),
                medicines: $('#medicines').val().split(',').map(m => m.trim()), 
                tests: $('#tests').val().split(',').map(t => t.trim()), 
                needRevisit: $('#needRevisit').is(':checked')
            };

            $.ajax({
                url: '/Doctor/SavePrescription',
                method: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(formData),
                success: function () {
                    alert('Prescription saved successfully!');
                    location.reload();
                },
                error: function () {
                    alert('Error saving prescription.');
                }
            });
        });
    </script>
}
