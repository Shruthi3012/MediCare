                        <label for="medicines" class="form-label">Medicines</label>
                        <textarea class="form-control" id="medicines" name="medicines" rows="2">@string.Join(", ", Model.Medicines)</textarea>
                    </div>
                    <div class="mb-3">
                        <label for="tests" class="form-label">Tests</label>
                        <textarea class="form-control" id="tests" name="tests" rows="2">@string.Join(", ", Model.Tests)</textarea>
                    </div>
                    <div class="form-check mb-3">
                        <input class="form-check-input" type="checkbox" id="needRevisit" name="needRevisit" @(Model.NeedRevisit ? "checked" : "") />
                        <label class="form-check-label" for="needRevisit">Need Revisit?</label>
                    </div>
                </div>
