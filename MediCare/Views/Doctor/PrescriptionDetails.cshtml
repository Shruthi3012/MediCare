@model MediCare.ViewModel.PrescriptionDetailsViewModel


<h3>Doctor Information</h3>
<p><strong>Name:</strong> @Model.DoctorName</p>
<p><strong>Specialization:</strong> @Model.Specialization</p>
<p><strong>Degree:</strong> @Model.Degree</p>

<h3>Patient Information</h3>
<p><strong>Name:</strong> @Model.PatientName</p>
<p><strong>Age:</strong> @Model.Age</p>
<p><strong>Email:</strong> @Model.Email</p>

<h3>Appointment Details</h3>
<p><strong>Appointment Date:</strong> @Model.BookedDate</p>
<p><strong>Appointment Time:</strong> @Model.BookedTime</p>
<p><strong>Patient Description:</strong> @Model.Description</p>


@*<h3>Prescription Details</h3>

@if ((Model.Medicines != null && Model.Medicines.Count > 0) || (Model.Tests != null && Model.Tests.Count > 0))
{
    @if (Model.Medicines != null && Model.Medicines.Count > 0)
